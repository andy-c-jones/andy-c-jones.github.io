---
interface Props {
    username: string;
}

const { username } = Astro.props as Props;
const skeletonCells = Array.from({ length: 53 * 7 });
---

<section class="contrib-card" data-github-contrib data-username={username}>
    <p class="contrib-card__meta" data-contrib-meta>Loading contribution summary…</p>
    <a
        class="contrib-link"
        href={`https://github.com/${username}`}
        target="_blank"
        rel="noreferrer"
        aria-label={`View ${username}'s GitHub profile`}
    >
        <div class="contrib-grid" data-contrib-grid role="img" aria-label={`${username} GitHub contributions graph`}>
            {
                skeletonCells.map(() => (
                    <span class="contrib-cell contrib-cell--skeleton" aria-hidden="true"></span>
                ))
            }
        </div>
    </a>
</section>

<script is:inline>
    const WEEKS_IN_GRAPH = 53;
    const DAYS_IN_WEEK = 7;
    const DAYS_IN_GRAPH = WEEKS_IN_GRAPH * DAYS_IN_WEEK;

    const toDateKey = (date) => date.toISOString().slice(0, 10);

    const getRollingYearTotal = (contributions) => {
        if (!Array.isArray(contributions)) {
            return 0;
        }

        const cutoff = new Date();
        cutoff.setDate(cutoff.getDate() - 365);
        const cutoffValue = cutoff.toISOString().slice(0, 10);

        return contributions.reduce((sum, entry) => {
            if (!entry || typeof entry.date !== "string" || typeof entry.count !== "number") {
                return sum;
            }
            return entry.date >= cutoffValue ? sum + entry.count : sum;
        }, 0);
    };

    const renderContributionGrid = (widget, contributions) => {
        const grid = widget.querySelector("[data-contrib-grid]");
        if (!grid) {
            return;
        }

        const byDate = new Map(
            contributions
                .filter((entry) => entry && typeof entry.date === "string")
                .map((entry) => [entry.date, entry])
        );

        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const start = new Date(today);
        start.setDate(today.getDate() - (DAYS_IN_GRAPH - 1));
        start.setDate(start.getDate() - start.getDay());

        const fragment = document.createDocumentFragment();

        for (let week = 0; week < WEEKS_IN_GRAPH; week += 1) {
            for (let day = 0; day < DAYS_IN_WEEK; day += 1) {
                const cellDate = new Date(start);
                cellDate.setDate(start.getDate() + week * 7 + day);
                const key = toDateKey(cellDate);
                const entry = byDate.get(key);
                const level = Number.isInteger(entry?.level) ? Math.min(Math.max(entry.level, 0), 4) : 0;
                const count = typeof entry?.count === "number" ? entry.count : 0;

                const cell = document.createElement("span");
                cell.className = `contrib-cell contrib-level-${level}`;
                cell.title = `${count} contributions on ${key}`;
                fragment.append(cell);
            }
        }

        grid.innerHTML = "";
        grid.append(fragment);
    };

    const setContributionMeta = (widget, total) => {
        const meta = widget.querySelector("[data-contrib-meta]");
        if (!meta) {
            return;
        }
        meta.textContent = `${total.toLocaleString("en-GB")} contributions in the last 12 months`;
    };

    const loadContributionData = async (widget, username) => {
        try {
            const response = await fetch(`https://github-contributions-api.jogruber.de/v4/${username}`);
            if (!response.ok) {
                throw new Error(`Contributions request failed with ${response.status}`);
            }

            const payload = await response.json();
            const contributions = Array.isArray(payload.contributions) ? payload.contributions : [];
            const total = getRollingYearTotal(contributions);
            setContributionMeta(widget, total);
            renderContributionGrid(widget, contributions);
        } catch {
            const meta = widget.querySelector("[data-contrib-meta]");
            if (meta) {
                meta.textContent = "Contribution summary unavailable";
            }
        }
    };

    const setupContributionWidgets = () => {
        const widgets = document.querySelectorAll("[data-github-contrib]");

        widgets.forEach((widget) => {
            const username = widget.getAttribute("data-username");
            if (!username) {
                return;
            }
            if (!widget.hasAttribute("data-contrib-loaded")) {
                widget.setAttribute("data-contrib-loaded", "true");
                loadContributionData(widget, username);
            }
        });
    };

    setupContributionWidgets();
    document.addEventListener("astro:after-swap", setupContributionWidgets);
</script>
