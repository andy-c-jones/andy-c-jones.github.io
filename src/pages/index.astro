---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import RecentPosts from "../components/RecentPosts.astro";
import GitHubContributions from "../components/GitHubContributions.astro";
import { getGitHubProfile } from "../utils/githubProfile";
import { getEntrySlug } from "../utils/content";

const allPosts = await getCollection("posts");
const recentPosts = allPosts
    .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
    .slice(0, 6)
    .map((post) => ({
        slug: getEntrySlug(post),
        title: post.data.title,
        date: post.data.date
    }));
const githubProfile = await getGitHubProfile("andy-c-jones");
const pageTitle = "Dark Peak Development";
---
<Layout pageTitle={pageTitle}>
    <section class="profile-layout">
        <article class="profile">
            <p class="profile__eyebrow">Profile</p>
            <img
                class="profile__avatar"
                src={githubProfile.avatarUrl}
                alt={`Portrait of ${githubProfile.name}`}
                width="192"
                height="192"
                loading="lazy"
            />
            <h1>{githubProfile.name}</h1>
            <p class="profile__summary">
                {githubProfile.bio}
            </p>
            <GitHubContributions username="andy-c-jones" />
            <ul class="pill-list" aria-label="GitHub profile details">
                <li>{githubProfile.publicRepos} public repos</li>
                <li>{githubProfile.followers} followers</li>
                <li>{githubProfile.following} following</li>
                {
                    githubProfile.location && (
                        <li class="pill-list__meta">
                            <svg class="pill-list__icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 1.5a7.5 7.5 0 0 0-7.5 7.5c0 5.56 6.49 12.83 6.77 13.13a1 1 0 0 0 1.46 0c.28-.3 6.77-7.57 6.77-13.13A7.5 7.5 0 0 0 12 1.5Zm0 10.5a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
                            </svg>
                            <span>{githubProfile.location}</span>
                        </li>
                    )
                }
                {
                    githubProfile.company && (
                        <li class="pill-list__meta">
                            <svg class="pill-list__icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M9 5.25A2.25 2.25 0 0 1 11.25 3h1.5A2.25 2.25 0 0 1 15 5.25V6h3.75A2.25 2.25 0 0 1 21 8.25v9A2.25 2.25 0 0 1 18.75 19.5H5.25A2.25 2.25 0 0 1 3 17.25v-9A2.25 2.25 0 0 1 5.25 6H9v-.75Zm1.5.75h3v-.75a.75.75 0 0 0-.75-.75h-1.5a.75.75 0 0 0-.75.75V6Z" />
                            </svg>
                            <span>{githubProfile.company}</span>
                        </li>
                    )
                }
            </ul>
            <p class="profile__summary">
                A technical advisory consultant, architect and Extreme Programming (XP) advocate.
                I have built and operated SaaS platforms in telecommunications, public security, logistics, insurance, loans, e-commerce, government and the arts.
                I also teach and coach developers to improve their understanding of modern agile methodologies, continuous delivery, infrastructure-as-code and cloud technologies.
                <br /><br />
                I am currently applying Extreme Programming (XP) practices to agentic AI workflows.
                I believe combining AI with strong analysis, testing, and validation techniques lets teams apply engineering rigor at lower cost.
                That leads to higher quality outcomes.
            </p>
            <ul class="pill-list" aria-label="Roles">
                <li>Software Engineer</li>
                <li>Architect</li>
                <li>Extreme Programming Advocate</li>
            </ul>
            <h2>Skills</h2>
            <div class="skills-grid">
                <span class="skills__icon-wrap" role="img" aria-label="Gleam" title="Gleam">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/gleam" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="Clojure" title="Clojure">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/clojure" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="Kotlin" title="Kotlin">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/kotlin" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="C#" title="C#">
                    <img class="skills__icon-svg" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/csharp/csharp-plain.svg" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label=".NET" title=".NET">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/dotnet" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="SQL Server" title="SQL Server">
                    <img class="skills__icon-svg" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/microsoftsqlserver/microsoftsqlserver-plain.svg" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="Terraform" title="Terraform">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/terraform" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="JavaScript" title="JavaScript">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/javascript" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="TypeScript" title="TypeScript">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/typescript" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="CSS" title="CSS">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/css" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="HTML" title="HTML">
                    <img class="skills__icon-svg" src="https://cdn.simpleicons.org/html5" alt="" loading="lazy" />
                </span>
                <span class="skills__icon-wrap" role="img" aria-label="GitHub Copilot" title="GitHub Copilot">
                    <svg class="skills__icon-copilot" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M23.922 16.997C23.061 18.492 18.063 22.02 12 22.02 5.937 22.02.939 18.492.078 16.997A.641.641 0 0 1 0 16.741v-2.869a.883.883 0 0 1 .053-.22c.372-.935 1.347-2.292 2.605-2.656.167-.429.414-1.055.644-1.517a10.098 10.098 0 0 1-.052-1.086c0-1.331.282-2.499 1.132-3.368.397-.406.89-.717 1.474-.952C7.255 2.937 9.248 1.98 11.978 1.98c2.731 0 4.767.957 6.166 2.093.584.235 1.077.546 1.474.952.85.869 1.132 2.037 1.132 3.368 0 .368-.014.733-.052 1.086.23.462.477 1.088.644 1.517 1.258.364 2.233 1.721 2.605 2.656a.841.841 0 0 1 .053.22v2.869a.641.641 0 0 1-.078.256Zm-11.75-5.992h-.344a4.359 4.359 0 0 1-.355.508c-.77.947-1.918 1.492-3.508 1.492-1.725 0-2.989-.359-3.782-1.259a2.137 2.137 0 0 1-.085-.104L4 11.746v6.585c1.435.779 4.514 2.179 8 2.179 3.486 0 6.565-1.4 8-2.179v-6.585l-.098-.104s-.033.045-.085.104c-.793.9-2.057 1.259-3.782 1.259-1.59 0-2.738-.545-3.508-1.492a4.359 4.359 0 0 1-.355-.508Zm2.328 3.25c.549 0 1 .451 1 1v2c0 .549-.451 1-1 1-.549 0-1-.451-1-1v-2c0-.549.451-1 1-1Zm-5 0c.549 0 1 .451 1 1v2c0 .549-.451 1-1 1-.549 0-1-.451-1-1v-2c0-.549.451-1 1-1Zm3.313-6.185c.136 1.057.403 1.913.878 2.497.442.544 1.134.938 2.344.938 1.573 0 2.292-.337 2.657-.751.384-.435.558-1.15.558-2.361 0-1.14-.243-1.847-.705-2.319-.477-.488-1.319-.862-2.824-1.025-1.487-.161-2.192.138-2.533.529-.269.307-.437.808-.438 1.578v.021c0 .265.021.562.063.893Zm-1.626 0c.042-.331.063-.628.063-.894v-.02c-.001-.77-.169-1.271-.438-1.578-.341-.391-1.046-.69-2.533-.529-1.505.163-2.347.537-2.824 1.025-.462.472-.705 1.179-.705 2.319 0 1.211.175 1.926.558 2.361.365.414 1.084.751 2.657.751 1.21 0 1.902-.394 2.344-.938.475-.584.742-1.44.878-2.497Z" />
                    </svg>
                </span>
            </div>
        </article>
        <RecentPosts posts={recentPosts} />
    </section>
</Layout>
