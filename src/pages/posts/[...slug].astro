---
import { getCollection, render } from "astro:content";
import MarkdownPostsLayout from "../../layouts/MarkdownPostsLayout.astro";
import { getEntrySlug } from "../../utils/content";

export const prerender = true;
export async function getStaticPaths() {
    const postEntries = await getCollection("posts");
    const sortedPosts = postEntries.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
    return postEntries.map((entry) => ({
        params: { slug: getEntrySlug(entry) },
        props: { entry, recentPosts: sortedPosts },
    }));
}

const { entry, recentPosts } = Astro.props;
const { Content } = await render(entry);
---

<MarkdownPostsLayout frontmatter={entry.data} recentPosts={recentPosts} currentSlug={getEntrySlug(entry)}>
    <Content />
</MarkdownPostsLayout>
