---
import { getCollection, render } from "astro:content";
import MarkdownPostsLayout from "../../layouts/MarkdownPostsLayout.astro";
import { getEntrySlug } from "../../utils/content";

export const prerender = true;
export async function getStaticPaths() {
    const postEntries = await getCollection("posts");
    return postEntries.map((entry) => ({
        params: { slug: getEntrySlug(entry) },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<MarkdownPostsLayout frontmatter={entry.data} currentSlug={getEntrySlug(entry)}>
    <Content />
</MarkdownPostsLayout>
